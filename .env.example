# --------------------------------------------------------------------------
# options-tracker - copy to .env and fill in. NEVER commit your real .env.
# On Linux, also restrict its permissions: chmod 600 .env
# --------------------------------------------------------------------------

# --- IBKR gateway login (IBEAM) -------------------------------------------
# PAPER vs LIVE is chosen by WHICH username you use here. IBKR paper accounts
# have their own separate login (often prefixed/suffixed). Use your paper
# credentials first to validate the stack safely.
#
# MULTI-USER: each IBKR login needs its own gateway container, because IBKR
# won't hold two Client Portal sessions on one login. User 1 uses IBEAM_ACCOUNT
# below; user 2 uses IBEAM_ACCOUNT_2. Only the gateway containers ever see these
# — the backend logs a user in by restarting their container, and their 2FA push
# goes to that person's own phone. Leave the _2 pair blank to stay single-user.
IBEAM_ACCOUNT=your_ibkr_username
IBEAM_PASSWORD=your_ibkr_password
IBEAM_ACCOUNT_2=
IBEAM_PASSWORD_2=
# Set to a large value (86400 = 24h) to disable auto-maintenance (auth is user-initiated).
# Do NOT use 0 â€” IBEAM interprets it as 1 second.
IBEAM_MAINTENANCE_INTERVAL=86400
# Seconds IBEAM waits for the CP Gateway login page to load.
IBEAM_PAGE_LOAD_TIMEOUT=30
# Advanced (optional): Fernet-encrypt the password instead of storing plaintext.
# Leave this COMMENTED OUT for normal use - an empty key breaks IBEAM login.
# You must also uncomment IBEAM_KEY in docker-compose.yml to use it (both
# steps are required together - an uncommented line with an empty key breaks
# login just as badly as a plaintext password with the line left commented).
# Generate a key:
#   docker run --rm python:3.12-slim python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Encrypt each IBEAM password with that same key:
#   docker run --rm -e KEY=<key> -e PW=<password> python:3.12-slim python -c "import os; from cryptography.fernet import Fernet; print(Fernet(os.environ['KEY']).encrypt(os.environ['PW'].encode()).decode())"
# Set the ciphertext as IBEAM_ACCOUNT/IBEAM_PASSWORD above (and the _2 pair).
# IBEAM_KEY=your_32_byte_urlsafe_base64_key

# --- Database --------------------------------------------------------------
POSTGRES_USER=options
# Generate with: openssl rand -base64 24
# To rotate an existing deployment: `ALTER USER options WITH PASSWORD '...';`
# inside `docker compose exec db psql -U options -d options`, then update this
# value and `docker compose up -d backend db-backup`.
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=options

# --- Backend ---------------------------------------------------------------
# Internal gateway URL (do not change unless you rename the service).
IBKR_GATEWAY_URL=https://ibkr-gateway:5000/v1/api
# The gateway uses a self-signed cert on the internal network. "false" skips
# verification (acceptable because the gateway is never exposed to the host).
# To harden, mount the gateway cert and set this to its path.
IBKR_GATEWAY_VERIFY=false
# Optional: pin a specific IBKR account id. Blank = auto-detect the first one.
IBKR_ACCOUNT_ID=
# Optional Redis. Leave blank to run without it (in-memory fallback).
# To enable: set this AND run `docker compose --profile redis up`.
REDIS_URL=
LOG_LEVEL=INFO

# Poller cadences (seconds) - steady state after the startup burst.
POLL_HEARTBEAT_SECONDS=45
POLL_POSITIONS_SECONDS=300
POLL_MARKETDATA_SECONDS=300
POLL_TRADES_SECONDS=300
POLL_MARKET_SECONDS=300
# Startup burst: poll data jobs every POLL_BURST_SECONDS for the first
# POLL_BURST_WINDOW_SECONDS so the UI fills (and IV history accumulates) fast,
# then jobs settle to the steady cadences above.
POLL_BURST_SECONDS=20
POLL_BURST_WINDOW_SECONDS=300

# --- Public price refresh (yfinance) -----------------------------------
# How often to pull prices/IV from public source (no IBKR auth needed).
POLL_PUBLIC_PRICE_SECONDS=300

# --- User-initiated login -----------------------------------------------
# Max seconds to wait for 2FA approval during login. Must exceed IBEAM startup
# (~120s) and stay under nginx proxy_read_timeout (180s). If you miss the push,
# just click "Pull Fresh Data" again — it restarts the gateway and sends a new
# one; a late approval is also picked up automatically.
PULL_LOGIN_TIMEOUT_SECONDS=120
# Docker container name of the ibkr-gateway service.
DOCKER_IBEAM_CONTAINER=options-tracker-ibkr-gateway-1

# --- Web exposure ----------------------------------------------------------
# The dashboard is served over HTTPS only. Before the first `docker compose
# up`, generate a local CA + server certificate:
#   bash scripts/gen-certs.sh
# then import certs/ca.crt into your OS/browser trust store (the script
# prints instructions for Windows/macOS/iOS/Android).
#
# Host interface for the dashboard port.
#   127.0.0.1  -> restrict to this machine only (default)
#   0.0.0.0    -> all interfaces; reach it from other LAN devices at
#                 https://<server-lan-ip>:8443
# SECURITY: the app has no built-in login yet, so binding beyond 127.0.0.1
# exposes the dashboard to whoever can reach that interface. For remote
# access, prefer a VPN/overlay network (e.g. Tailscale/WireGuard): set
# APP_BIND to that interface's IP and add it to EXTRA_SANS (see
# scripts/gen-certs.sh) before regenerating certs. Never port-forward this
# port to the internet. See README "Network access (LAN / homelab)".
APP_BIND=127.0.0.1
APP_PORT=8443

# --- Authentication ----------------------------------------------------------
# Single shared login gates every page and API route (except the healthcheck).
# Generate a hash for your password (prompts twice, prints the hash — nothing
# is written to disk):
#   docker compose run --rm --no-deps --entrypoint python backend -m app.cli.hash_password
# IMPORTANT: wrap the hash in SINGLE quotes below — it contains `$` characters
# that `docker compose` would otherwise try to interpolate as variables.
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=
AUTH_SESSION_TTL_HOURS=168
# Only set to false for plain-HTTP local dev — never in a real deployment.
AUTH_COOKIE_SECURE=true

# --- IBKR Flex Web Service (historical trades) -----------------------
# Set up once in IBKR Account Management -> Settings -> Flex Web Service.
# These are the fallback for user 1; prefer the per-user IBKR_USER*_FLEX_* below.
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# --- Users (multi-account) -------------------------------------------------
# One block per person, numbered from 1 with no gaps. LEAVE THIS WHOLE SECTION
# BLANK for a single-user setup: the backend then falls back to the legacy
# IBKR_GATEWAY_URL / DOCKER_IBEAM_CONTAINER / IBKR_ACCOUNT_ID / IBKR_FLEX_* vars
# above and behaves exactly as before.
#
# To add a second person: fill in both blocks, set IBEAM_ACCOUNT_2 / _PASSWORD_2
# with their IBKR login, then `docker compose up -d`. Each user gets their own
# watchlist, alert thresholds, and Flex query; both can be logged in at once.
#
# LABEL       shown in the UI's user switcher
# CONTAINER   docker name of their gateway; depends on the compose project name
#             (`options-tracker` here) — check with `docker compose ps`
# ACCOUNT_ID  optional pin; blank = auto-detect on login
# FLEX_*      optional per-user Flex Web Service query; blank = skipped
IBKR_USER1_LABEL=
IBKR_USER1_GATEWAY_URL=https://ibkr-gateway:5000/v1/api
IBKR_USER1_CONTAINER=options-tracker-ibkr-gateway-1
IBKR_USER1_ACCOUNT_ID=
IBKR_USER1_FLEX_TOKEN=
IBKR_USER1_FLEX_QUERY_ID=

IBKR_USER2_LABEL=
IBKR_USER2_GATEWAY_URL=https://ibkr-gateway-2:5000/v1/api
IBKR_USER2_CONTAINER=options-tracker-ibkr-gateway-2-1
IBKR_USER2_ACCOUNT_ID=
IBKR_USER2_FLEX_TOKEN=
IBKR_USER2_FLEX_QUERY_ID=

# --- Automated DB backups (db-backup service) ------------------------------
# Gzipped pg_dump written to ./backups on the host. Defaults: nightly, keep 7.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP_DAYS=7
# Encrypt backups at rest with age (https://age-encryption.org). Generate a
# keypair once:
#   docker run --rm alpine:3 sh -c "apk add -q age && age-keygen"
# Store the PRIVATE key (AGE-SECRET-KEY-...) somewhere off this server (a
# password manager) - it is the only way to restore. Put the printed PUBLIC
# key (age1...) below. Leave blank to write unencrypted backups (a WARNING is
# logged every cycle when unset).
# Restore: age -d -i key.txt backups/options-<ts>.sql.gz.age | gunzip | docker compose exec -T db psql -U options -d options
AGE_RECIPIENT=
